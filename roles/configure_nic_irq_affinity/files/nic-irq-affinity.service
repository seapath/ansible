[Unit]
Description=NIC IRQ affinity monitor
After=network-pre.target

[Service]
Type=simple
Restart=always
RestartSec=1
ExecStart=/usr/local/bin/nic-irq-monitor.sh

[Install]
WantedBy=multi-user.target
