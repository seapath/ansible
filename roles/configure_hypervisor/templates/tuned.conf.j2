[main]
include=realtime-virtual-host
summary=Seapath profile for RT host (Seapath Rt Host = SRH)

[variables]
isolated_cores={{ isolcpus | default('') }}
non_isolated_cores_expanded=${f:cpulist_unpack:${non_isolated_cores}}

[sysctl]
kernel.printk=3 1 1 7

[sysfs]
/sys/module/kvm/parameters/halt_poll_ns = 0

[bootloader]
cmdline_srh=+processor.max_cstate=1 intel_idle.max_cstate=1 cpufreq.default_governor=performance rcu_nocb_poll

[irqbalance]
# Prevent tuned from stopping and restarting irqbalance when applying this
# profile. The realtime base profile's [irqbalance] plugin causes a ~1s IRQ
# redistribution that breaks Corosync heartbeats and triggers quorum loss.
# irqbalance is masked system-wide; NIC IRQs are managed by nic-irq-monitor
# and isolated CPUs are covered by isolcpus=managed_irq.
enabled=0

[scheduler]
# isolcpus= in the kernel cmdline already prevents the scheduler from
# assigning tasks to isolated cores. Disable tuned's own process-affinity
# management (isolated_cores=) to avoid conflicts with QEMU threads pinned
# by the seapath hook and containers pinned at the cgroup level.
isolated_cores=
# for i in `pgrep rcuc` ; do grep Cpus_allowed_list /proc/$i/status ; done
group.rcuc=0:f:10:*:^\[rcuc
