cukinia_log "$(_colorize yellow "--- check systemd settings ---")"

test_id "SEAPATH-00199" as "No systemd service failed" cukinia_systemd_failed

ESSENTIAL_SERVICES_EXTRA=""
_cukinia_extra_services_dir="/etc/cukinia/extra-essential-services.d"
if [ -d "$_cukinia_extra_services_dir" ]; then
    for _cukinia_extra_services_file in "$_cukinia_extra_services_dir"/*; do
        [ -f "$_cukinia_extra_services_file" ] || continue
        while IFS= read -r _cukinia_extra_service || [ -n "$_cukinia_extra_service" ]; do
            case "$_cukinia_extra_service" in
                ''|\#*) continue ;;
            esac
            ESSENTIAL_SERVICES_EXTRA="${ESSENTIAL_SERVICES_EXTRA}|${_cukinia_extra_service}"
        done < "$_cukinia_extra_services_file"
    done
fi

{% if deploy_cukinia_tests_extra_essential_services | default([]) %}
ESSENTIAL_SERVICES_EXTRA="${ESSENTIAL_SERVICES_EXTRA}|\
{{ deploy_cukinia_tests_extra_essential_services | join('|\\\n') }}"
{% endif %}

ESSENTIAL_SERVICES_DEBIAN="\
console-setup|\
containerd|\
dpdk|\
hddtemp|\
keyboard-setup|\
kthread-taskset|\
lm-sensors|\
logd|\
lvm2-pvscan|\
netfilter-persistent|\
nginx|\
nginxquadlet|\
openipmi|\
ovs-record-hostname|\
quadlet-macvlan-network|\
rc.local|\
sysfsutils|\
systemd-backlight|\
systemd-fsck|\
systemd-update-utmp-runlevel|\
systemd-update-utmp|\
wtmpdb-update-boot"

ESSENTIAL_SERVICES_SLES="\
dracut-shutdown|\
iscsi|\
kbdsettings|\
kernel-sysctl|\
klog|\
ovs-delete-transient-ports|\
soft-reboot-cleanup|\
systemd-fsck-root|\
systemd-vconsole-setup"

ESSENTIAL_SERVICES_COMMON="\
apparmor|\
atd|\
auditd|\
blk-availability|\
ceph-[a-Z0-9-]*|\
{% if seapath_distro == "Debian" %}chrony{% else %}chronyd{% endif %}|\
chrony-wait|\
conntrackd|\
corosync|\
cron|\
{% if seapath_distro == "SLES" %}dbus-broker{% else %}dbus{% endif %}|\
dm-event|\
getty|\
irqbalance|\
kmod-static-nodes|\
libvirt-guests|\
libvirtd|\
logrotate|\
lvm2-monitor|\
{% if seapath_distro == "Debian" %}openvswitch-switch{% else %}openvswitch{% endif %}|\
ovs-vswitchd|\
ovsdb-server|\
pacemaker|\
podman|\
polkit|\
ptp_vsock|\
ptpstatus|\
rbdmap|\
serial-getty@ttyS0|\
{% if seapath_distro == "Debian" %}smartmontools{% else %}smartd{% endif %}|\
snmpd|\
{% if seapath_distro == "Debian" %}ssh{% else %}sshd{% endif %}|\
seapath-config_ovs|\
syslog-ng|\
sysstat|\
systemd-binfmt|\
systemd-journal-flush|\
systemd-journald|\
systemd-logind|\
systemd-machined|\
systemd-modules-load|\
systemd-network-generator|\
systemd-networkd-persistent-storage|\
systemd-networkd-wait-online|\
systemd-networkd|\
systemd-random-seed|\
systemd-remount-fs|\
systemd-resolved|\
systemd-sysctl|\
systemd-sysusers|\
systemd-tmpfiles-setup-dev-early|\
systemd-tmpfiles-setup-dev|\
systemd-tmpfiles-setup|\
systemd-udev-load-credentials|\
systemd-udev-trigger|\
systemd-udevd|\
systemd-user-sessions|\
team0_x|\
timemaster|\
tuned|\
user-runtime-dir|\
user|\
virtlogd"

ESSENTIAL_SERVICES="(\
{% if seapath_distro == "Debian" %}
$ESSENTIAL_SERVICES_DEBIAN|\
{% elif seapath_distro == "SLES" %}
$ESSENTIAL_SERVICES_SLES|\
{% endif %}
$ESSENTIAL_SERVICES_COMMON\
$ESSENTIAL_SERVICES_EXTRA\
)"

UNRECOGNIZED_SERVICES="$(systemctl list-units --type service --plain --no-pager --no-legend | awk -F ' ' '{ print $1}' | grep -Ev '^'${ESSENTIAL_SERVICES}'(@.*)?'.service'$')"

if [ "$UNRECOGNIZED_SERVICES" != "" ]; then
    cukinia_log "$(_colorize red Unrecognized services: $UNRECOGNIZED_SERVICES)"
fi

test_id "SEAPATH-00200" as "No unrecognized service enabled" \
    cukinia_test "$UNRECOGNIZED_SERVICES" = ""
