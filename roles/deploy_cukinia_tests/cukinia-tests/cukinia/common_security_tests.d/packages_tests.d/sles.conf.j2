grep_is_essential_cmd="grep -Eq"
for p in $EXPECTED_PACKAGES; do
    grep_is_essential_cmd="$grep_is_essential_cmd -e (^|\s)$p(\s|$)"
done

# Check if package is in the list of essential packages
package_is_essential() {
    echo $1 | $grep_is_essential_cmd
}

set_dependency_chain() {
    dependency_chain=""
    for i in "$@"; do
        if [ -n "$dependency_chain" ]; then
            dependency_chain="$dependency_chain -> $i"
        else
            dependency_chain="$i"
        fi
    done
}

REQUIRED_PACKAGES=""
UNNEEDED_PACKAGES=""

# Parameters:
# $1 is the package name
# $2 is the dependency chain to avoid infinite loops. Leave empty on initial call.
# Return: 0 if the package is required by an explicitly installed package, 1 if not.
package_is_required() {
    if package_is_essential "$1" || echo "$REQUIRED_PACKAGES" | grep -Eq "(^|\s)$1(\s|$)"; then
        set_dependency_chain $2 $1

        for r in $2 $1; do
            if ! echo "$REQUIRED_PACKAGES" | grep -Eq "(^|\s)$r(\s|$)"; then
                REQUIRED_PACKAGES="$REQUIRED_PACKAGES $r"
            fi
        done

        return 0
    fi

    # Detect packages installed with weak requirements (e.g. recommends, suggest, ...)
    requires="$(zypper --no-remote -q se -i --requires-pkg $1 | tail -n+4 | cut -d'|' -f2)"
    if [ -z "$requires" ] || echo "$UNNEEDED_PACKAGES" | grep -Eq "(^|\s)$1(\s|$)"; then
        set_dependency_chain $2 $1

        if ! echo "$UNNEEDED_PACKAGES" | grep -Eq "(^|\s)$1(\s|$)"; then
            UNNEEDED_PACKAGES="$UNNEEDED_PACKAGES $r"
        fi

        return 1
    fi

    for r in $requires; do
        if echo "$2" | grep -Eq "(^|\s)$r(\s|$)"; then
            continue
        fi

        if package_is_required "$r" "$2 $1"; then
            return 0
        fi
    done

    # No required package found
    return 1
}

for p in $(zypper --no-remote -q se -i -t package | tail -n+4 | cut -d'|' -f2); do
    if ! package_is_required "$p"; then
        cukinia_log "$(_colorize red Unneeded package: $p \(dependency chain: $dependency_chain\))"
    fi
done

test_id "SEAPATH-00198" as "No unneded packages installed" \
    cukinia_test "$UNNEEDED_PACKAGES" = ""
