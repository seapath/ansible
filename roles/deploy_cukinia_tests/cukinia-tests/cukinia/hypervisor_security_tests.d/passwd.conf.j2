passwd=" \
    {{ admin_user }} \
    ansible \
    _apt \
    backup \
    bin \
    _chrony \
    daemon \
    Debian-snmp \
{% if ansible_distribution == 'Debian' and ansible_distribution_release == 'trixie' %}
    dnsmasq \
{% endif %}
    games \
{% if inventory_hostname in groups.get('cluster_machines', []) %}
    ceph \
    hacluster \
{% endif %}
{% if inventory_hostname in groups.get('cluster_machines', []) and (is_using_cephadm | default(false)) %}
    containerized-ceph \
    cephadm \
{% endif %}
    irc \
    libvirt-qemu \
    list \
{% if inventory_hostname in groups.get('cluster_machines', []) %}
    libvirtadmin \
{% endif %}
    lp \
    mail \
    man \
    messagebus \
    news \
    nobody \
    polkitd \
    proxy \
    root \
    sshd \
    sync \
    sys \
    systemd-network \
    systemd-resolve \
    uucp \
    uuidd \
    www-data \
"
args="-v"
for g in ${passwd}; do
    args="$args -e $g"
done

cukinia_log "$(_colorize yellow "--- check /etc/passwd ---")"

nb_passwd=$(echo $passwd | wc -w)

PASSWD_EXTRA_USERS=$(grep $args /etc/passwd | wc -l)
PASSWD_NB_USERS=$(cat /etc/passwd | wc -l)

test_id "SEAPATH-00047" as "/etc/passwd only contains expected users" \
    cukinia_test $PASSWD_EXTRA_USERS -eq 0 -a $PASSWD_NB_USERS -eq $nb_passwd
